# ============================================
# NexBank Backend Environment Configuration
# ============================================

# Application
NODE_ENV=development
PORT=5000
APP_NAME=NexBank
CLIENT_URL=http://localhost:5173
API_VERSION=v1

# MongoDB
MONGODB_URI=mongodb://localhost:27017/nexbank
MONGODB_OPTIONS=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=86400

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-min-32-chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_COOKIE_EXPIRY=7

# OTP
OTP_LENGTH=6
OTP_EXPIRY=300
OTP_MAX_ATTEMPTS=3
OTP_COOLDOWN=60
OTP_RESEND_LIMIT=3

# Account Security
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_TIME=30
SUSPICIOUS_IP_THRESHOLD=3

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=NexBank <noreply@nexbank.com>

# SMS (Twilio)
TWILIO_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE=+1234567890

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=nexbank

# Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpeg,jpg,png,pdf

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# Session
SESSION_MAX_PER_USER=5
SESSION_TIMEOUT=24h

# Encryption
ENCRYPTION_KEY=your-32-char-encryption-key-here
AES_IV_LENGTH=16

# Logging
LOG_LEVEL=info
LOG_FILE=logs/nexbank.log

# Admin
ADMIN_EMAIL=admin@nexbank.com
ADMIN_PASSWORD=Admin@123456

# Default Bank Config
BANK_CODE=NXB
BANK_NAME=NexBank
IFSC_PREFIX=NXB0
MIN_BALANCE=1000
DAILY_TRANSFER_LIMIT=500000
MONTHLY_TRANSFER_LIMIT=5000000
